{
  "name": "nw-tracker",
  "private": true,
  "engines": {
    "node": "24.11.1"
  },
  "workspaces": ["server", "client"],
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "scripts": {
    "typecheck": "npm run typecheck -w nw-tracker-server && npm run typecheck -w nw-tracker-client",
    "dev:server": "npm run dev -w nw-tracker-server",
    "dev:client": "npm run dev -w nw-tracker-client",
    "migrate": "npm run migrate -w nw-tracker-server",
    "import:excel": "npm run import:excel -w nw-tracker-server",
    "import:cfraser-inbox": "npm run import:cfraser-inbox -w nw-tracker-server",
    "repair:cc-metadata": "npm run repair:cc-metadata -w nw-tracker-server",
    "repair:cc-web-paste-pdf-reconcile": "npm run repair:cc-web-paste-pdf-reconcile -w nw-tracker-server",
    "repair:cc-pdfs-qpdf": "python3 server/scripts/repair-cc-statement-pdfs-qpdf.py --inbox",
    "parse:cc-pdfs": "PYTHONPATH=server/scripts/.pdf_deps python3 server/scripts/parse-cc-statement-pdfs.py",
    "restore:cc-corrupt-pdfs": "PYTHONPATH=server/scripts/.pdf_deps python3 server/scripts/restore-cc-corrupt-pdfs.py",
    "check:cc-parse": "PYTHONPATH=server/scripts/.pdf_deps python3 server/scripts/check-cc-statement-parse.py",
    "parse:checking-cartola-pdfs": "PYTHONPATH=server/scripts/.pdf_deps python3 server/scripts/parse-checking-cartola-pdfs.py",
    "export:checking-cartola-screenshots-csv": "npm run export:checking-cartola-screenshots-csv -w nw-tracker-server",
    "import:checking-cartola-screenshots": "npm run import:checking-cartola-screenshots -w nw-tracker-server",
    "clear:checking-persisted-valuations": "npm run clear:checking-persisted-valuations -w nw-tracker-server",
    "import:cc-parsed": "npm run import:cc-parsed -w nw-tracker-server",
    "backfill:cc-valuations-from-ledger": "npm run backfill:cc-valuations-from-ledger -w nw-tracker-server",
    "backfill:cc-cuota-gaps": "npm run backfill:cc-cuota-gaps -w nw-tracker-server",
    "fetch-uf": "npm run fetch-uf -w nw-tracker-server",
    "parse:payroll-liquidaciones": "PYTHONPATH=server/scripts/.pdf_deps python3 server/scripts/parse-payroll-liquidaciones.py",
    "import:payroll-liquidaciones": "npm run import:payroll-liquidaciones -w nw-tracker-server"
  }
}
