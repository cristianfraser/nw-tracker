{
  "name": "nw-tracker-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "migrate": "tsx -e \"import './src/db.ts'\"",
    "import:excel": "tsx scripts/import-excel-history.ts",
    "import:depto-expenses": "tsx scripts/import-depto-apartment-expenses.ts",
    "parse:cc-pdfs": "PYTHONPATH=scripts/.pdf_deps python3 scripts/parse-cc-statement-pdfs.py",
    "import:cc-parsed": "tsx scripts/import-cc-parsed-to-db.ts",
    "backfill:cc-valuations-from-ledger": "tsx scripts/backfill-cc-valuations-from-installment-ledger.ts",
    "backfill:cc-cuota-gaps": "tsx scripts/backfill-cc-installment-gaps.ts",
    "fetch-uf": "tsx scripts/fetch-sii-uf-daily.ts",
    "fintual:token": "tsx scripts/fintual-api-access-token.ts",
    "fintual:fetch-goals": "tsx scripts/fintual-api-fetch-goals.ts",
    "fintual:apply-valuations": "tsx scripts/fintual-api-apply-valuations.ts",
    "fintual:sync": "tsx scripts/fintual-api-fetch-goals.ts && tsx scripts/fintual-api-apply-valuations.ts",
    "sync:all": "tsx scripts/global-sync.ts",
    "backfill:sbif-utm-ipc": "tsx scripts/backfill-sbif-utm-ipc.ts",
    "backfill:sbif-fx-eur": "tsx scripts/backfill-sbif-fx-eur-daily.ts",
    "probe:bcentral-series": "tsx scripts/probe-bcentral-series.ts",
    "sync:equity-eod": "tsx scripts/sync-equity-eod.ts",
    "prune:future-month-end-valuations": "tsx scripts/prune-future-month-end-valuations.ts",
    "afp:uno:cert-sync": "tsx scripts/afp-uno-cert-sync.ts",
    "afp:uno:cert-pdf-to-csv": "tsx scripts/afp-uno-cert-pdf-to-csv.ts",
    "afp:uno:fetch-cuotas": "tsx scripts/afp-uno-fetch-cuotas.ts",
    "afp:uno:backfill-quetalmiafp": "tsx scripts/afp-uno-backfill-quetalmiafp.ts",
    "afp:uno:fetch-cuota-website": "tsx scripts/afp-uno-fetch-cuota-website.ts",
    "afp:uno:spot-from-website": "tsx scripts/afp-uno-spot-from-website.ts",
    "afp:uno:apply-valuation": "tsx scripts/afp-uno-apply-valuation.ts",
    "afp:uno:reconcile-cuotas": "tsx scripts/afp-uno-reconcile-cuotas.ts",
    "afp:uno:refresh-cert-derived": "tsx scripts/afp-uno-refresh-cert-derived.ts",
    "afp:modelo:cert-pdf-to-csv": "tsx scripts/afp-modelo-cert-pdf-to-csv.ts",
    "afp:modelo:antecedentes-pdf-to-csv": "tsx scripts/afp-modelo-antecedentes-pdf-to-csv.ts",
    "afp:modelo:traspaso-pdf-to-csv": "tsx scripts/afp-modelo-traspaso-pdf-to-csv.ts",
    "crypto:apply-valuation": "tsx scripts/crypto-apply-valuation.ts",
    "retag:fintual-state-contributions": "tsx scripts/retag-fintual-state-contributions.ts",
    "apv:apply-flow-overrides": "tsx scripts/apply-apv-a-flow-overrides.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "xlsx": "^0.18.5"
  }
}
