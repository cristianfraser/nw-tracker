# Pin Node for installs (pair with .nvmrc for nvm).
engine-strict=true

# Supply-chain hardening: refuse to install any registry package
# published less than 3 days ago. Blunts compromised-publish attacks
# (e.g. nx / chalk-style incidents) by giving time for detection.
#
# Config: https://docs.npmjs.com/cli/v11/using-npm/config#min-release-age
# Requires npm >= 11.10. Mutually exclusive with `before`.
# Value is a plain integer (days). No "d" suffix.
min-release-age=3
