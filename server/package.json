    "repair:checking-cartola-missing-movements": "tsx scripts/repair-checking-cartola-missing-movements.ts",
    "repair:checking-gastos-categories": "tsx scripts/repair-checking-gastos-categories.ts",
    "db:snapshot": "tsx scripts/db-snapshot.ts",
    "repair:cc-usd-statements": "tsx scripts/import-missing-cc-usd-statements.ts",
    "import:depto-expenses": "tsx scripts/import-depto-apartment-expenses.ts",
    "reconcile:real-estate-links": "tsx scripts/reconcile-real-estate-expense-links.ts",
    "parse:cc-pdfs": "PYTHONPATH=scripts/.pdf_deps python3 scripts/parse-cc-statement-pdfs.py",
    "restore:cc-corrupt-pdfs": "PYTHONPATH=scripts/.pdf_deps python3 scripts/restore-cc-corrupt-pdfs.py",
    "parse:checking-cartola-pdfs": "PYTHONPATH=scripts/.pdf_deps python3 scripts/parse-checking-cartola-pdfs.py",
    "parse:cuenta-vista-cartola-pdfs": "PYTHONPATH=scripts/.pdf_deps python3 scripts/parse-cuenta-vista-cartola-pdfs.py",
