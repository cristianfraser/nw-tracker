    "backfill:fx-bid-ask-from-movements": "tsx scripts/backfill-fx-bid-ask-from-movements.ts",
    "backfill:crypto-coingecko-eod": "tsx scripts/backfill-crypto-coingecko-eod.ts",
    "backfill:bolsa-santiago-eod": "tsx scripts/backfill-bolsa-santiago-eod.ts",
    "backfill:bcentral-uf": "tsx scripts/backfill-bcentral-uf.ts",
    "backfill:watchlist-equity-history": "tsx scripts/backfill-watchlist-equity-history.ts",
    "probe:bcentral-series": "tsx scripts/probe-bcentral-series.ts",
    "sync:equity-eod": "tsx scripts/sync-equity-eod.ts",
    "prune:future-month-end-valuations": "tsx scripts/prune-future-month-end-valuations.ts",
    "afp:uno:fetch-cuotas": "tsx scripts/afp-uno-fetch-cuotas.ts",
    "afp:uno:backfill-quetalmiafp": "tsx scripts/afp-uno-backfill-quetalmiafp.ts",
    "afp:uno:fetch-cuota-website": "tsx scripts/afp-uno-fetch-cuota-website.ts",
    "afp:uno:spot-from-website": "tsx scripts/afp-uno-spot-from-website.ts",
    "afp:uno:apply-valuation": "tsx scripts/afp-uno-apply-valuation.ts",
    "crypto:apply-valuation": "tsx scripts/crypto-apply-valuation.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && NW_TRACKER_TEST_DB=nw-tracker.test.db vitest run",
    "profile:dashboard": "tsx scripts/profile-dashboard.ts",
    "parse:payroll-liquidaciones": "python3 scripts/parse-payroll-liquidaciones.py",
    "import:payroll-liquidaciones": "tsx scripts/import-payroll-liquidaciones.ts",
    "db:verify-backup": "tsx scripts/verify-db-backup.ts"
