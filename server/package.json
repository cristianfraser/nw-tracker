    "import:cc-parsed": "tsx scripts/import-cc-parsed-to-db.ts",
    "repair:cc-installment-duplicate-purchases": "tsx scripts/repair-cc-installment-duplicate-purchases.ts",
    "import:checking-cartolas": "tsx scripts/import-checking-cartolas.ts",
    "import:cuenta-vista-cartolas": "tsx scripts/import-cuenta-vista-cartolas.ts",
    "import:checking-cartola-screenshots": "tsx scripts/import-checking-cartola-screenshots.ts",
    "clear:checking-persisted-valuations": "tsx scripts/clear-checking-persisted-valuations.ts",
