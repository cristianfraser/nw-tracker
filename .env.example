# Copy to `.env` in the repo root (`.env` is gitignored). Never commit real secrets.

# Fintual API — https://fintual.cl/api-docs/index.html
# Scripts: npm run fintual:token | fintual:fetch-goals | fintual:apply-valuations -w nw-tracker-server
FINTUAL_EMAIL=
FINTUAL_PASSWORD=
# Browser `_fintual_session_cookie` value (DevTools → Network → request headers → Cookie).
# GET /api/goals: scripts send X-User-Email + X-User-Token and this Cookie, matching the browser.
FINTUAL_COOKIE=

# Banco Central de Chile — BDE API (GetSeries)
# https://si3.bcentral.cl/estadisticas/Principal1/Web_Services/doc_es.htm
# Register at BDE; same credentials as the statistics web portal.
BCENTRAL_EMAIL=
BCENTRAL_PASSWORD=
# Optional overrides for default series codes (see server/src/bcentralSeries.ts):
# BCENTRAL_SERIES_USD=F073.TCO.PRE.Z.D
# BCENTRAL_SERIES_EUR=F072.CLP.EUR.N.O.D
# BCENTRAL_SERIES_UF=F073.UFF.PRE.Z.D
# BCENTRAL_SERIES_UTM=F073.UTR.PRE.Z.M
# BCENTRAL_SERIES_IPC=G073.IPC.IND.2018.M
# BCENTRAL_MIN_REQUEST_INTERVAL_MS=3000
# BCENTRAL_BACKOFF_BASE_MS=900000
